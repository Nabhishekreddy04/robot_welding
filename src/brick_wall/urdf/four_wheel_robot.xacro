<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="mobile_manipulator">

  <!-- ========================================================== -->
  <!--                     PROPERTIES                              -->
  <!-- ========================================================== -->

  <!-- Mobile Base -->
    <xacro:property name="wheel_radius"  value="0.15"/>
    <xacro:property name="wheel_width"   value="0.10"/>
    <xacro:property name="body_length"   value="1.2"/>
    <xacro:property name="body_width"    value="0.9"/>
    <xacro:property name="body_height"   value="0.30"/>
    <!-- Camera is mounted below base_link (lidar remains above). -->
    <xacro:property name="depth_cam_mount_x" value="${body_length/2 - 0.08}"/>
    <xacro:property name="depth_cam_mount_z" value="-${body_height/2 + 0.03}"/>

  <!-- Manipulator -->
  <!-- Manipulator (scaled ×2) -->
<xacro:property name="link1_radius"    value="0.20"/>
<xacro:property name="link1_length"    value="0.20"/>
<xacro:property name="arm_radius"      value="0.06"/>
<xacro:property name="arm_length"      value="0.60"/>
<xacro:property name="wrist_size"      value="0.06"/>
<xacro:property name="wrist_length"    value="0.20"/>
<xacro:property name="ee_radius"       value="0.08"/>
<xacro:property name="ee_length"       value="0.20"/>
<xacro:property name="finger_x"        value="0.02"/>
<xacro:property name="finger_y"        value="0.02"/>
<xacro:property name="finger_z"        value="0.10"/>
<xacro:property name="default_mass" value="3.0"/>
<xacro:property name="default_inertia" value="0.5"/>

  <!-- ========================================================== -->
  <!--                     MATERIALS                               -->
  <!-- ========================================================== -->
  <material name="silver">
    <color rgba="0.75 0.75 0.75 1"/>
  </material>
  <material name="blue">
    <color rgba="0.0 0.0 1.0 1.0"/>
  </material>
  <material name="black">
    <color rgba="0.0 0.0 0.0 1.0"/>
  </material>
  <material name="white">
    <color rgba="1.0 1.0 1.0 1.0"/>
  </material>

  <!-- ========================================================== -->
  <!--                        MACROS                               -->
  <!-- ========================================================== -->

  <!-- Default Inertial -->
  <xacro:macro name="default_inertial">
    <inertial>
      <mass value="${default_mass}"/>
      <inertia ixx="${default_inertia}" iyy="${default_inertia}" izz="${default_inertia}"
               ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>
  </xacro:macro>

  <!-- Cylinder Link -->
  <xacro:macro name="cylinder_link" params="name radius length ox oy oz gazebo_material turn_gravity_off:=false">
    <link name="${name}">
      <visual>
        <origin rpy="0 0 0" xyz="${ox} ${oy} ${oz}"/>
        <geometry>
          <cylinder radius="${radius}" length="${length}"/>
        </geometry>
        <material name="silver"/>
      </visual>
      <collision>
        <origin rpy="0 0 0" xyz="${ox} ${oy} ${oz}"/>
        <geometry>
          <cylinder radius="${radius}" length="${length}"/>
        </geometry>
      </collision>
      <xacro:default_inertial/>
    </link>
    <gazebo reference="${name}">
      <material>${gazebo_material}</material>
      <turnGravityOff>${turn_gravity_off}</turnGravityOff>
    </gazebo>
  </xacro:macro>

  <!-- Box Link -->
  <xacro:macro name="box_link" params="name sx sy sz ox oy oz gazebo_material turn_gravity_off:=false">
    <link name="${name}">
      <visual>
        <origin rpy="0 0 0" xyz="${ox} ${oy} ${oz}"/>
        <geometry>
          <box size="${sx} ${sy} ${sz}"/>
        </geometry>
        <material name="silver"/>
      </visual>
      <collision>
        <origin rpy="0 0 0" xyz="${ox} ${oy} ${oz}"/>
        <geometry>
          <box size="${sx} ${sy} ${sz}"/>
        </geometry>
      </collision>
      <xacro:default_inertial/>
    </link>
    <gazebo reference="${name}">
      <material>${gazebo_material}</material>
      <turnGravityOff>${turn_gravity_off}</turnGravityOff>
    </gazebo>
  </xacro:macro>

  <xacro:macro name="lidar" params="parent">
    
    <link name="lidar_link">
      <visual>
        <geometry>
          <cylinder radius="0.05" length="0.05"/>
        </geometry>
      </visual>
      <collision>
        <geometry>
          <cylinder radius="0.05" length="0.05"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.2"/>
        <inertia ixx="0.001" iyy="0.001" izz="0.001"
                 ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>

    <joint name="lidar_joint" type="fixed">
      <parent link="${parent}"/>
      <child link="lidar_link"/>
      <origin xyz="${body_length/2 - 0.05} 0 ${body_height/2 + 0.025}"/>
    </joint>

    <gazebo reference="lidar_link">
      <sensor name="lidar_sensor" type="ray">
        <always_on>true</always_on>
        <visualize>true</visualize>
        <update_rate>10</update_rate>

        <ray>
          <scan>
            <horizontal>
              <samples>360</samples>
              <min_angle>-3.14</min_angle>
              <max_angle>3.14</max_angle>
            </horizontal>
          </scan>

          <range>
            <min>0.1</min>
            <max>3.0</max>
          </range>
        </ray>

        <plugin name="gazebo_ros_laser" filename="libgazebo_ros_ray_sensor.so">
          <ros>
            <remapping>~/out:=scan</remapping>
          </ros>
          <output_type>sensor_msgs/LaserScan</output_type>
          <topic_name>/scan</topic_name>
          <frame_name>lidar_link</frame_name>
        </plugin>

      </sensor>
    </gazebo>

  </xacro:macro>

  <xacro:macro name="depth_camera" params="parent">
    <link name="depth_camera_link">
      <visual>
        <geometry>
          <box size="0.10 0.05 0.04"/>
        </geometry>
        <material name="black"/>
      </visual>
      <collision>
        <geometry>
          <box size="0.10 0.05 0.04"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.15"/>
        <inertia ixx="0.0002" iyy="0.0002" izz="0.0002"
                 ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>

    <joint name="depth_camera_joint" type="fixed">
      <parent link="${parent}"/>
      <child link="depth_camera_link"/>
      <!-- Under-front mounting with stronger downward tilt for floor-gap observation. -->
      <origin xyz="${depth_cam_mount_x} 0 ${depth_cam_mount_z}" rpy="0 0.62 0"/>
    </joint>

    <gazebo reference="depth_camera_link">
      <sensor name="depth_camera_sensor" type="depth">
        <always_on>true</always_on>
        <visualize>true</visualize>
        <update_rate>15</update_rate>
        <camera>
          <horizontal_fov>1.047</horizontal_fov>
          <image>
            <width>640</width>
            <height>480</height>
            <format>R8G8B8</format>
          </image>
          <clip>
            <near>0.10</near>
            <far>8.0</far>
          </clip>
        </camera>

        <plugin name="gazebo_ros_depth_camera" filename="libgazebo_ros_camera.so">
          <camera_name>depth_camera</camera_name>
          <frame_name>depth_camera_link</frame_name>
          <image_topic_name>/depth_camera/image_raw</image_topic_name>
          <camera_info_topic_name>/depth_camera/camera_info</camera_info_topic_name>
          <depth_image_topic_name>/depth_camera/depth/image_raw</depth_image_topic_name>
          <depth_image_camera_info_topic_name>/depth_camera/depth/camera_info</depth_image_camera_info_topic_name>
          <point_cloud_topic_name>/depth_camera/points</point_cloud_topic_name>
        </plugin>
      </sensor>
    </gazebo>
  </xacro:macro>

  <!-- CALL LIDAR -->
  <xacro:lidar parent="base_link"/>

  <!-- CALL DEPTH CAMERA -->
  <xacro:depth_camera parent="base_link"/>

  <!-- Wheel Macro -->
  <xacro:macro name="wheel" params="name x y">
    <link name="${name}_wheel">
      <visual>
        <origin xyz="0 0 0" rpy="1.5707 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="black"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="1.5707 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="2.0"/>
        <inertia ixx="0.001" iyy="0.001" izz="0.001"
                 ixy="0.0" ixz="0.0" iyz="0.0"/>
      </inertial>
    </link>

    <joint name="${name}_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${name}_wheel"/>
      <origin xyz="${x} ${y} -${body_height/2}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <dynamics damping="2.0" friction="0.5"/>
    </joint>

    <gazebo reference="${name}_wheel">
      <mu1>0.9</mu1>
      <mu2>0.9</mu2>
      <kp>500000.0</kp>
      <kd>100.0</kd>
      <maxVel>1</maxVel>
      <minDepth>0.003</minDepth>
      <material>Gazebo/Black</material>
      <turnGravityOff>false</turnGravityOff>
    </gazebo>
  </xacro:macro>

  <!-- Finger Macro -->
  <xacro:macro name="finger" params="name joint_name lower upper oy">
  <link name="${name}">
    <visual>
      <origin xyz="0 0 ${finger_z/2}"/>
      <geometry>
        <box size="${finger_x} ${finger_y} ${finger_z}"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 ${finger_z/2}"/>
      <geometry>
        <box size="${finger_x} ${finger_y} ${finger_z}"/>
      </geometry>
    </collision>
    <xacro:default_inertial/>
  </link>

  <joint name="${joint_name}" type="prismatic">
    <axis xyz="0 1 0"/>
    <limit effort="20" lower="${lower}" upper="${upper}" velocity="0.2"/>
    <parent link="link6"/>
    <child link="${name}"/>
    <origin xyz="0 ${oy} ${ee_length/2 + 0.05}"/>
  </joint>
</xacro:macro>

  <!-- ========================================================== -->
  <!--                     MOBILE BASE                             -->
  <!-- ========================================================== -->

  <!-- base_link is the ROOT of the entire robot -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="${body_length} ${body_width} ${body_height}"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry>
        <box size="${body_length} ${body_width} ${body_height}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="20.0"/>
      <inertia ixx="0.1" iyy="0.1" izz="0.1"
               ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>
  </link>

  <gazebo reference="base_link">
    <material>Gazebo/Blue</material>
    <turnGravityOff>false</turnGravityOff>
  </gazebo>

  <!-- 4 Wheels -->
  <xacro:wheel name="front_left"  x="0.44"  y="0.44"/>
  <xacro:wheel name="front_right" x="0.44"  y="-0.44"/>
  <xacro:wheel name="rear_left"   x="-0.44" y="0.44"/>
  <xacro:wheel name="rear_right"  x="-0.44" y="-0.44"/>
  <!-- ========================================================== -->
  <!--                   MANIPULATOR MOUNT                         -->
  <!-- ========================================================== -->

  <!--
    Mounted at center-top of mobile base
    z = body_height / 2 = 0.075
  -->
  <joint name="base_to_arm" type="fixed">
    <parent link="base_link"/>
    <child link="arm_base_link"/>
    <origin xyz="0 0 0.15" rpy="0 0 0"/>
  </joint>

  <!-- Flat base plate of the arm — gravity off so it stays fixed -->
  <xacro:cylinder_link name="arm_base_link"
    radius="${link1_radius}" length="0.02"
    ox="0" oy="0" oz="0.01"
    gazebo_material="Gazebo/White"
    turn_gravity_off="false"/>

  <!-- ========================================================== -->
  <!--               MANIPULATOR LINKS & JOINTS                   -->
  <!-- ========================================================== -->

  <!-- LINK 1 — Shoulder Rotator (rotates around Z) -->
  <!-- LINK 1 -->
<xacro:cylinder_link name="link1"
  radius="${link1_radius}" length="${link1_length}"
  ox="0" oy="0" oz="0.10"
  gazebo_material="Gazebo/Black"
  turn_gravity_off="false"/>

<joint name="joint1" type="continuous">
  <origin rpy="0 0 0" xyz="0 0 0.02"/>
  <parent link="arm_base_link"/>
  <child link="link1"/>
  <axis xyz="0 0 1"/>
  <dynamics damping="5.0" friction="1.0"/>
</joint>

<!-- LINK 2 -->
<xacro:cylinder_link name="link2"
  radius="${arm_radius}" length="${arm_length}"
  ox="0" oy="0" oz="0.30"
  gazebo_material="Gazebo/Blue"
  turn_gravity_off="false"/>

<joint name="joint2" type="revolute">
  <origin rpy="0 0 0" xyz="0 0 0.16"/>
  <parent link="link1"/>
  <child link="link2"/>
  <axis xyz="0 1 0"/>
  <limit lower="-1.57" upper="1.57" effort="100" velocity="1"/>
  <dynamics damping="5.0" friction="1.0"/>
</joint>

<!-- LINK 3 -->
<xacro:cylinder_link name="link3"
  radius="${arm_radius}" length="${arm_length}"
  ox="0" oy="0" oz="0.30"
  gazebo_material="Gazebo/Black"
  turn_gravity_off="false"/>

<joint name="joint3" type="revolute">
  <origin rpy="0 0 0" xyz="0 0 0.56"/>
  <parent link="link2"/>
  <child link="link3"/>
  <axis xyz="0 1 0"/>
  <limit lower="-2.57" upper="2.57" effort="100" velocity="1"/>
  <dynamics damping="5.0" friction="1.0"/>
</joint>

<!-- LINK 4 -->
<xacro:box_link name="link4"
  sx="${wrist_size}" sy="${wrist_size}" sz="${wrist_length}"
  ox="0" oy="0" oz="0.10"
  gazebo_material="Gazebo/Blue"
  turn_gravity_off="false"/>

<joint name="joint4" type="revolute">
  <origin rpy="0 0 0" xyz="0 0 0.56"/>
  <parent link="link3"/>
  <child link="link4"/>
  <axis xyz="0 0 1"/>
  <limit lower="-3.14" upper="3.14" effort="100" velocity="1"/>
  <dynamics damping="5.0" friction="1.0"/>
</joint>

<!-- LINK 5 -->
<xacro:box_link name="link5"
  sx="${wrist_size}" sy="${wrist_size}" sz="${wrist_length}"
  ox="0" oy="0" oz="0.10"
  gazebo_material="Gazebo/Black"
  turn_gravity_off="false"/>

<joint name="joint5" type="revolute">
  <origin rpy="0 0 0" xyz="0 0 0.16"/>
  <parent link="link4"/>
  <child link="link5"/>
  <axis xyz="0 1 0"/>
  <limit lower="-2.57" upper="2.57" effort="100" velocity="1"/>
  <dynamics damping="5.0" friction="1.0"/>
</joint>

<!-- LINK 6 -->
<xacro:cylinder_link name="link6"
  radius="${ee_radius}" length="${ee_length}"
  ox="0" oy="0" oz="0.10"
  gazebo_material="Gazebo/Blue"
  turn_gravity_off="false"/>

<joint name="joint6" type="revolute">
  <origin rpy="0 0 0" xyz="0 0 0.16"/>
  <parent link="link5"/>
  <child link="link6"/>
  <axis xyz="1 0 0"/>
  <limit lower="-2.57" upper="2.57" effort="100" velocity="1"/>
  <dynamics damping="5.0" friction="1.0"/>
</joint>

<!-- FINGERS -->
<xacro:finger name="finger1" joint_name="f_joint1"
  lower="0.0"    upper="0.040"  oy="-0.050"/>

<xacro:finger name="finger2" joint_name="f_joint2"
  lower="-0.040" upper="0.0"    oy="0.050"/>

  <!-- ========================================================== -->
  <!--                   ROS2 CONTROL                              -->
  <!-- ========================================================== -->

  <ros2_control name="GazeboSystem" type="system">
    <hardware>
      <plugin>gazebo_ros2_control/GazeboSystem</plugin>
    </hardware>

    <!-- ARM JOINTS — position controlled -->
    <joint name="joint1">
      <command_interface name="position">
        <param name="min">-3.14</param>
        <param name="max">3.14</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="joint2">
      <command_interface name="position">
        <param name="min">-1.57</param>
        <param name="max">1.57</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="joint3">
      <command_interface name="position">
        <param name="min">-2.57</param>
        <param name="max">2.57</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="joint4">
      <command_interface name="position">
        <param name="min">-3.14</param>
        <param name="max">3.14</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="joint5">
      <command_interface name="position">
        <param name="min">-2.57</param>
        <param name="max">2.57</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="joint6">
      <command_interface name="position">
        <param name="min">-2.57</param>
        <param name="max">2.57</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <!-- GRIPPER JOINTS — effort controlled -->
    <joint name="f_joint1">
      <command_interface name="effort">
        <param name="min">-20</param>
        <param name="max">20</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="f_joint2">
      <command_interface name="effort">
        <param name="min">-20</param>
        <param name="max">20</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

  </ros2_control>

  <!-- ========================================================== -->
  <!--                   GAZEBO PLUGINS                            -->
  <!-- ========================================================== -->

  <!-- Differential Drive — 4-wheel skid steer mobile base -->
  <gazebo>
    <plugin name="skid_steer_drive" filename="libgazebo_ros_diff_drive.so">
      <ros>
        <remapping>cmd_vel:=/cmd_vel</remapping>
        <remapping>odom:=/odom</remapping>
        
      </ros>

      <num_wheel_pairs>2</num_wheel_pairs>

      <left_joint>front_left_joint</left_joint>
      <right_joint>front_right_joint</right_joint>
      <left_joint>rear_left_joint</left_joint>
      <right_joint>rear_right_joint</right_joint>

      <wheel_separation>0.88</wheel_separation>
      
      <wheel_diameter>0.30</wheel_diameter>
      

      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_link</robot_base_frame>

      <!-- Higher limits reduce the visible lag when teleop starts/stops motion. -->
      <max_wheel_torque>160</max_wheel_torque>
      <max_wheel_acceleration>4.0</max_wheel_acceleration>

      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>true</publish_wheel_tf>
      <update_rate>100</update_rate>
    </plugin>
  </gazebo>

  <!-- ROS2 Control — arm joints -->
  <gazebo>
    <plugin name="gazebo_ros2_control" filename="libgazebo_ros2_control.so">
        <parameters>$(find brick_wall)/config/controllers.yaml</parameters>
        <robot_param>robot_description</robot_param>
        <robot_param_node>robot_state_publisher</robot_param_node>
    </plugin>
  </gazebo>

</robot>